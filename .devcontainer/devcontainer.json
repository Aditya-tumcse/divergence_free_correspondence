{
	"name": "deform",
	"features": {
		"ghcr.io/devcontainers/features/node:1": {
			"version": "20"
		}
	},
	"build": {
		"dockerfile": "../docker/Dockerfile_develop",
		"args": {
			"user": "${localEnv:USER}"
		}
	},
	"postCreateCommand": "conan profile detect --force && conan install . --output-folder=build --build=missing -s build_type=Release -s compiler.cppstd=20 && npm install -g @anthropic-ai/claude-code && bash .devcontainer/setup_rtk.sh && bash scripts/install-hooks.sh",
	"remoteUser": "${localEnv:USER}",
	"updateRemoteUserUID": true,
	"mounts": [
		{
			"type": "bind",
			"source": "${localEnv:HOME}/.ssh",
			"target": "${localEnv:HOME}/.ssh"
		}
	],
	"customizations": {
		"vscode": {
			"settings": {},
			"extensions": [
				"ms-azuretools.vscode-docker",
				"ms-toolsai.jupyter",
				"ms-python.python",
				"ms-vscode.cpptools-extension-pack",
				"mhutchie.git-graph",
				"Gruntfuggly.todo-tree",
				"Anthropic.claude-code"
			]
		}
	}
}
